# CSMS WebSocket base — VCP connects to ${WS_URL}/${CP_ID}
WS_URL=wss://scenergy-api-production.up.railway.app/ocpp

# Must match scenergy-backend DEMO_CHARGE_POINT_ID (prisma/demo-charge-point.ts)
CP_ID=a1111111-1111-4111-a111-111111111111

# Session length before container exits (seconds). Default 30 minutes.
VCP_TTL_SECONDS=1800

ADMIN_PORT=9999
PORT=9999
